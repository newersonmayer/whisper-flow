# NUNCA versionar segredos nem dados pessoais
.env

# ambiente virtual (recriado pelo instalar.bat)
venv/

# caches Python
__pycache__/
*.pyc

# logs e dados gerados em runtime (conteudo pessoal)
*.log
transcricoes/
pendentes/
audios/

# vocabulario pessoal (cada maquina tem o seu; editavel pela aba Vocabulario)
vocabulario.txt

# preferencias pessoais (aba Ajustes; cada maquina tem o seu)
settings.json

# artefatos temporarios
_test_*
_inv_*

# gerado pelo instalador (contem o caminho local da instalacao)
INSTRUCAO-CLAUDE-CODE.md
