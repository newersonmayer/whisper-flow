# Chave da API da OpenAI. Peca ao Sr. Mayer e cole abaixo. NAO compartilhe.
OPENAI_API_KEY=sk-cole-sua-chave-aqui

# Modelo de transcricao. gpt-4o-mini-transcribe e mais preciso que o whisper-1.
# Se a chave/projeto nao tiver acesso a ele (erro 403), troque por:  whisper-1
WHISPER_MODEL=gpt-4o-mini-transcribe

# Tecla de atalho (segura, fala, solta). Padrao: f9.
# Use teclas de funcao (f1..f12) - letras atrapalham a digitacao normal.
HOTKEY=f9
